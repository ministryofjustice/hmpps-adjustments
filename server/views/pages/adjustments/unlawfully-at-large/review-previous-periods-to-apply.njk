{% extends "../../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set pageTitle = applicationName + " - Review UAL to be applied" %}
{% set mainClasses = "app-container govuk-body" %}
{% block beforeContent %}
    {{ super() }}
    <nav>
        {{ govukBackLink({
            text: "Back",
            href: backLink
        }) }}
    </nav>
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds govuk-body">
            <span class="govuk-caption-xl">Adjustments</span>
            <h1 class="govuk-heading-l">Review UAL to be applied</h1>
            <p class="govuk-body">This is the previous period of UAL that will be applied to the current release dates calculation.</p>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <form class="form" method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                {% set rows = [] %}
                {% set total = 0 %}
                {% for previousPeriod in previousUalAdjustmentsForReview %}
                    <input type="hidden" name="reviewedUalPeriod" value="{{ previousPeriod.id }}" />
                    {% set rows = (rows.push([
                        { text: previousPeriod.fromDate | date("D MMMM YYYY"), attributes: { "data-qa": "period-to-apply-" + previousPeriod.id } },
                        { text: previousPeriod.toDate | date("D MMMM YYYY") },
                        { text: previousPeriod.prisonName },
                        { text: previousPeriod.type | formatUalType },
                        { text: previousPeriod.days }
                    ]), rows) %}
                    {% set total = total + previousPeriod.days %}
                {% endfor %}
                {% set rows = (rows.push([
                    { text: "Total days", classes: "govuk-!-font-weight-bold" },
                    { text: "" },
                    { text: "" },
                    { text: "" },
                    { text: total, classes: "govuk-!-font-weight-bold", attributes: { "data-qa": "total-days-to-apply" } }
                ]), rows) %}
                {{ govukTable({
                    attributes: {
                        "data-qa": "previous-ual-periods-to-apply-table",
                        "id": "previous-ual-periods-to-apply-table"
                    },
                    head: [
                        { text: "First day" },
                        { text: "Last day" },
                        { text: "Entered by" },
                        { text: "Type" },
                        { text: "Number of days" }
                    ],
                    rows: rows
                }) }}

                <div class="govuk-button-group">
                    {{ govukButton({
                        text: "Confirm and save",
                        type: submit,
                        preventDoubleClick: true,
                        attributes: {'data-qa': 'continue-button'}
                    }) }}

                    {{ govukButton({
                        text: "Cancel",
                        href: cancelLink,
                        classes: "govuk-button--secondary",
                        attributes: {'data-qa': 'cancel-button'}
                    }) }}
                </div>
            </form>
        </div>
    </div>
{% endblock %}