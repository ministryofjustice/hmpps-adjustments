{% extends "../../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set pageTitle = applicationName + " - Review previous periods of UAL" %}
{% set mainClasses = "app-container govuk-body" %}
{% block beforeContent %}
    {{ super() }}
    <nav>
        {{ govukBackLink({
            text: "Back",
            href: backLink
        }) }}
    </nav>
{% endblock %}

{% block content %}
    {% if form.errors.length %}
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                {{ govukErrorSummary({
                    titleText: "There is a problem",
                    errorList: form.errorList(),
                    attributes: { "data-qa": "error-summary" }
                }) }}
            </div>
        </div>
    {% endif %}

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds govuk-body">
            <span class="govuk-caption-xl">Adjustments</span>
            <h1 class="govuk-heading-l">Review previous periods of UAL</h1>
            <p class="govuk-body">Select the UAL that applies to the release date calculation. If none apply, select ‘no previous periods of UAL apply’.</p>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <form class="form" method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                {% set rows = [] %}
                {% for previousPeriod in previousUalAdjustmentsForReview %}
                    <input type="hidden" name="reviewedUalPeriod" value="{{ previousPeriod.id }}" />
                    {% set checkboxHtml %}
                        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                            <div class="govuk-checkboxes__item">
                                <input class="govuk-checkboxes__input" id="previous-ual-periods-{{ previousPeriod.id }}" name="selectedUalPeriod" type="checkbox" value="{{ previousPeriod.id }}">
                                <label class="govuk-label govuk-checkboxes__label" for="previous-ual-periods-{{ previousPeriod.id }}">
                                    <span class="govuk-visually-hidden">Select the period from {{ previousPeriod.fromDate | date("D MMMM YYYY") }} to {{ previousPeriod.toDate | date("D MMMM YYYY") }}</span>
                                </label>
                            </div>
                        </div>
                    {% endset %}
                    {% set rows = (rows.push([
                        { html: checkboxHtml },
                        { text: previousPeriod.fromDate | date("D MMMM YYYY") },
                        { text: previousPeriod.toDate | date("D MMMM YYYY") },
                        { text: previousPeriod.prisonName },
                        { text: previousPeriod.type | formatUalType },
                        { text: previousPeriod.days }
                    ]), rows) %}
                {% endfor %}
                {{ govukTable({
                    attributes: {
                        "data-qa": "previous-ual-periods-table",
                        "id": "previous-ual-periods-table"
                    },
                    head: [
                        { html: '<span class="govuk-visually-hidden">Select the UAL that applies to the release date calculation</span>' },
                        { text: "First day" },
                        { text: "Last day" },
                        { text: "Entered by" },
                        { text: "Type" },
                        { text: "Number of days" }
                    ],
                    rows: rows
                }) }}


                {{ govukCheckboxes({
                    name: "selectedUalPeriod",
                    classes: "govuk-checkboxes--small",
                    fieldset: {
                        legend: {
                            text: "If no previous periods apply",
                            classes: "govuk-fieldset__legend--s"
                        }
                    },
                    items: [
                        {
                            value: "none",
                            text: "No previous periods of UAL apply ",
                            id: "none-apply-checkbox"
                        }
                    ]
                }) }}

                <div class="govuk-button-group">
                    {{ govukButton({
                        text: "Continue",
                        type: submit,
                        preventDoubleClick: true,
                        attributes: {'data-qa': 'continue-button'}
                    }) }}

                    {{ govukButton({
                        text: "Cancel",
                        href: cancelLink,
                        classes: "govuk-button--secondary",
                        attributes: {'data-qa': 'cancel-button'}
                    }) }}
                </div>
            </form>
        </div>
    </div>
{% endblock %}